# Copy to `backend/.env` (gitignored) and fill in secrets.

MERCADOPAGO_ACCESS_TOKEN=
# Trial signup creates an MP customer per email. To sign up again with the same email after
# deleting your DB tenant, remove that customer in the Mercado Pago dashboard (or use another email).

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=server
DB_SSLMODE=disable
JWT_SECRET=change-me-for-local-dev

# Dev fixtures (deterministic local users / companies). Keep false outside local dev.
# When true, backend runs db/seed/local_dev_users.sql after migrations on startup.
# SEED_LOCAL_DEV_USERS=false
#
# Fixture logins/passwords: ../LOCAL_DEV_ACCOUNTS.md (repo root)

# SIGNUP_ALLOW_MOCK_PAYMENT=false

# Billing: catalog USD (billing.MonthlyListPriceUSD) → ARS invoices using dólar bolsa (MEP-style).
# Optional: override bolsa JSON URL (default https://dolarapi.com/v1/dolares/bolsa).
# BILLING_MEP_BOLSA_URL=
# Fallback ARS/USD if the MEP API is unreachable (recommended in production).
# BILLING_USD_ARS_RATE=1450
# Surcharge on the MEP reference before converting USD list to ARS (default 0.07 = 7%).
# BILLING_FX_BUFFER_FRACTION=0.07

# Optional cron: POST /internal/billing/trigger-renewal (header X-Billing-Secret)
# BILLING_RENEWAL_SECRET=
# BILLING_STUB_AUTO_CHARGE=false

# Optional: Android APK direct download (GCS). Service account must be able to sign URLs for this bucket.
# GCS_RELEASES_BUCKET=
# ANDROID_RELEASE_OBJECT=releases/enpunto.apk
# GCS_RELEASES_SIGNED_URL_MINUTES=15

# Transactional email (Resend). Set EMAIL_ENABLED=true and provide RESEND_API_KEY + EMAIL_FROM to send.
# EMAIL_ENABLED=false
# RESEND_API_KEY=
# EMAIL_FROM="Remitos <onboarding@yourdomain.com>"
# EMAIL_REPLY_TO=
# PUBLIC_SITE_URL=https://example.com
