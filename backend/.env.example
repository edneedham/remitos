# Copy to `backend/.env` (gitignored) and fill in secrets.

MERCADOPAGO_ACCESS_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:3000

DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=server
DB_SSLMODE=disable
JWT_SECRET=change-me-for-local-dev

# SIGNUP_ALLOW_MOCK_PAYMENT=false

# Optional: Android APK direct download (GCS). Service account must be able to sign URLs for this bucket.
# GCS_RELEASES_BUCKET=
# ANDROID_RELEASE_OBJECT=releases/enpunto.apk
# GCS_RELEASES_SIGNED_URL_MINUTES=15
