# Formspree form ID (get from formspree.io)
FORMSPREE_FORM_ID=

# Public site URL (no trailing slash). Used for signup QR codes so scans open
# the correct host in production. If omitted, the QR uses the current origin.
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Backend API base URL (no trailing slash), e.g. http://localhost:8080
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Mercado Pago public key (browser). Used to tokenize the card on signup (PCI-safe).
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-...

# Dev only: skip Mercado Pago UI and send a mock card token (requires SIGNUP_ALLOW_MOCK_PAYMENT=true on the API).
# Used for signup and for /dashboard/activate-subscription (simulated activation).
# NEXT_PUBLIC_SIGNUP_USE_MOCK_PAYMENT=true

# Client: log trial onboarding events to the browser console as JSON (validation without GTM/GA). Use 1, true, or yes.
# NEXT_PUBLIC_ANALYTICS_DEBUG=1
