<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Blue right half of circle -->
    <path
        android:pathData="M100,0 A100,100 0 0,1 100,200 L100,0 Z"
        android:fillColor="#1A6FEE" />

    <!-- Red left half of circle (bottom-left quadrant + lower part of top-left) -->
    <path
        android:pathData="M100,0 A100,100 0 0,0 100,200 L100,0 Z"
        android:fillColor="#C8102E" />

    <!-- White cross: horizontal bar -->
    <path
        android:pathData="M4,62 L90,62 L90,76 L4,76 Z"
        android:fillColor="#FFFFFF" />

    <!-- White cross: vertical bar -->
    <path
        android:pathData="M44,8 L58,8 L58,100 L44,100 Z"
        android:fillColor="#FFFFFF" />

</vector>
